<%- include('partials/header') %>

  <style>
    /* --- PHỤC HỒI NÚT 3 GẠCH, CHỈ GIẤU CHỮ BỊ TRÙNG --- */
    .thanh-menu-chinh {
      background: transparent !important;
      padding: 15px 15px 0 !important;
      text-align: right !important;
      /* Đẩy nút 3 gạch sang góc phải cho xịn */
    }

    .thanh-menu-chinh h1,
    .thanh-menu-chinh p,
    .thanh-menu-chinh .lien-he-header,
    .thanh-menu-chinh hr {
      display: none !important;
      /* Lệnh bắn tỉa: Chỉ xóa chữ và đường kẻ, tha mạng cho nút 3 gạch */
    }

    /* --- PHỤC HỒI NỀN WEB GRADIENT SANG TRỌNG --- */
    body {
      background: linear-gradient(135deg, #fdfbf7 0%, #eef7f6 100%);
      background-attachment: fixed;
      min-height: 100vh;
      margin: 0;
      font-family: 'Quicksand', sans-serif;
      color: #333;
    }

    /* --- BANNER ẢNH TRANG CHỦ (ĐÃ KÉO CAO LÊN TRÔNG HOÀNH TRÁNG HƠN) --- */
    .banner-chinh {
      text-align: center;
      max-width: 1200px;
      margin: 0 auto 15px;
      padding: 0 15px;
    }

    .banner-chinh img {
      width: 100%;
      height: 350px;
      /* <--- KÉO CAO TRÊN MÁY TÍNH LÊN 350px */
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 8px 20px rgba(10, 124, 118, 0.15);
    }

    /* --- DANH MỤC VUỐT NGANG --- */
    .danh-muc-nhanh {
      display: flex;
      overflow-x: auto;
      gap: 12px;
      padding: 5px 15px 15px;
      margin-bottom: 15px;
      white-space: nowrap;
      -ms-overflow-style: none;
      scrollbar-width: none;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .danh-muc-nhanh::-webkit-scrollbar {
      display: none;
    }

    .chip-danh-muc {
      background-color: #ffffff;
      color: #0A7C76;
      padding: 10px 22px;
      border-radius: 25px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.06);
      border: 1px solid transparent;
    }

    .chip-danh-muc:hover,
    .chip-danh-muc.active {
      background: linear-gradient(135deg, #0A7C76, #149c95);
      color: #ffffff;
      box-shadow: 0 6px 15px rgba(10, 124, 118, 0.3);
      transform: translateY(-2px);
    }

    /* --- THANH TÌM KIẾM --- */
    .khung-tim-kiem {
      max-width: 600px;
      margin: 15px auto 20px;
      padding: 0 15px;
      position: relative;
    }

    .khung-tim-kiem .icon-tim-kiem {
      position: absolute;
      left: 35px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      pointer-events: none;
      color: #0a7c76;
    }

    .khung-tim-kiem input {
      width: 100%;
      padding: 16px 20px 16px 50px;
      border-radius: 30px;
      border: 1px solid #e0eceb;
      font-size: 15px;
      outline: none;
      box-shadow: 0 6px 15px rgba(0, 0, 0, 0.04);
      transition: all 0.3s ease;
      box-sizing: border-box;
      background: #fff;
    }

    .khung-tim-kiem input:focus {
      box-shadow: 0 6px 20px rgba(10, 124, 118, 0.15);
      border-color: #0a7c76;
    }

    /* --- LƯỚI SẢN PHẨM HIỆN ĐẠI --- */
    .luoi-san-pham {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 25px;
      padding: 0 15px 40px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .the-san-pham {
      border-radius: 20px;
      overflow: hidden;
      text-align: center;
      background: #fff;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      padding-bottom: 20px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      border: none;
      position: relative;
    }

    .the-san-pham:hover {
      transform: translateY(-8px);
      box-shadow: 0 15px 35px rgba(10, 124, 118, 0.15);
    }

    .the-san-pham img {
      width: 100%;
      height: 280px;
      object-fit: cover;
      border-bottom: 1px solid #f0f0f0;
    }

    .the-san-pham h3 {
      font-size: 16px;
      color: #2c3e50;
      margin: 15px 15px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      height: 44px;
      font-weight: 700;
      line-height: 1.4;
    }

    .the-san-pham a.btn-chi-tiet {
      display: inline-block;
      padding: 10px 25px;
      background: linear-gradient(135deg, #0A7C76, #149c95);
      color: #ffffff;
      text-decoration: none;
      border-radius: 25px;
      font-weight: bold;
      font-size: 14px;
      transition: all 0.3s;
      box-shadow: 0 4px 10px rgba(10, 124, 118, 0.2);
    }

    .the-san-pham a.btn-chi-tiet:hover {
      background: linear-gradient(135deg, #08615c, #0A7C76);
      box-shadow: 0 6px 15px rgba(10, 124, 118, 0.3);
    }

    /* --- TỐI ƯU CỰC MƯỢT CHO ĐIỆN THOẠI --- */
    @media (max-width: 768px) {
      .luoi-san-pham {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        padding: 0 12px 40px;
      }

      .the-san-pham {
        border-radius: 16px;
        padding-bottom: 15px;
      }

      .the-san-pham img {
        height: 190px;
      }

      .the-san-pham h3 {
        font-size: 14px;
        margin: 12px 8px;
        height: 40px;
      }

      .the-san-pham a.btn-chi-tiet {
        padding: 8px 18px;
        font-size: 12px;
      }

      .banner-chinh img {
        height: 220px;
        /* <--- KÉO CAO TRÊN ĐIỆN THOẠI LÊN 220px */
      }
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .the-san-pham {
      animation: fadeInUp 0.6s ease-out forwards;
    }
  </style>

  <div class="banner-chinh">
    <img src="/nen-web.jpg" alt="Hoa Tươi Thanh Ngọc" onerror="this.style.display='none'">
  </div>

  <div class="khung-tim-kiem">
    <span class="icon-tim-kiem">🔍</span>
    <input type="text" id="oTimKiem" placeholder="Bạn cần tìm hoa gì (vd: khai trương, bó hoa)...">
  </div>

  <div class="danh-muc-nhanh">
    <a href="/" class="chip-danh-muc active">Tất Cả</a>
    <a href="/?danhmuc=Hoa Khai Trương" class="chip-danh-muc">Khai Trương</a>
    <a href="/?danhmuc=Hoa Kính Viếng" class="chip-danh-muc">Kính Viếng</a>
    <a href="/?danhmuc=Bó Hoa" class="chip-danh-muc">Bó Hoa</a>
    <a href="/?danhmuc=Lẵng/Giỏ Hoa" class="chip-danh-muc">Lẵng/Giỏ</a>
    <a href="/?danhmuc=Hoa Để Bàn" class="chip-danh-muc">Hoa Để Bàn</a>
    <a href="/?danhmuc=Hoa Baby" class="chip-danh-muc">Hoa Baby</a>
  </div>

  <div class="luoi-san-pham" id="danhSachHoa">
    <% danhSach.forEach((item, index)=> { %>
      <div class="the-san-pham" data-delay="<%= (index * 0.05).toFixed(2) %>">
        <a href="/san-pham/<%= item.slug %>">
          <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>" decoding="async">
        </a>
        <h3 class="ten-hoa-hien-thi">
          <%= item.ten %>
        </h3>
        <a href="/san-pham/<%= item.slug %>" class="btn-chi-tiet">Xem Chi Tiết</a>
      </div>
      <% }) %>
  </div>

  <script>
    document.getElementById('oTimKiem').addEventListener('input', function () {
      let tuKhoa = this.value.toLowerCase().trim();
      let cacSanPham = document.querySelectorAll('.the-san-pham');
      cacSanPham.forEach(sanPham => {
        let tenHoa = sanPham.querySelector('.ten-hoa-hien-thi').textContent.toLowerCase();
        sanPham.style.display = tenHoa.includes(tuKhoa) ? 'block' : 'none';
      });
    });

    document.querySelectorAll('.the-san-pham').forEach(element => {
      const delay = element.getAttribute('data-delay');
      element.style.animationDelay = delay + 's';
    });
  </script>

  <%- include('partials/footer') %>