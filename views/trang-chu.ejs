<%- include('partials/header') %>

  <style>
    /* 1. XÓA LOGO TRÙNG LẶP & FIX NỀN WEB */
    .logo-shop,
    .thanh-menu-chinh .logo-area,
    .logo-tron,
    .logo-area,
    .logo-shop-dua {
      display: none !important;
    }

    body {
      background: linear-gradient(135deg, #fdfbf7 0%, #eef7f6 100%) !important;
      background-attachment: fixed !important;
      font-family: 'Quicksand', sans-serif;
    }

    /* 2. BANNER CHÍNH */
    .banner-chinh-anh {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 8px 20px rgba(10, 124, 118, 0.15);
    }

    /* 3. HIỆU ỨNG HOA BAY & ZOOM */
    .the-san-pham {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s ease-out;
    }

    .the-san-pham.hien-ra {
      opacity: 1;
      transform: translateY(0);
    }

    .the-san-pham:hover {
      transform: translateY(-10px) !important;
    }

    .the-san-pham img {
      transition: transform 0.4s ease;
    }

    .the-san-pham:hover img {
      transform: scale(1.08) !important;
    }

    /* 4. NÚT XEM THÊM */
    .khu-vuc-nut {
      text-align: center;
      margin: 40px 0;
      width: 100%;
    }

    #nut-xem-them {
      background: #0a7c76;
      color: white;
      border: none;
      padding: 12px 40px;
      border-radius: 30px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 4px 15px rgba(10, 124, 118, 0.2);
    }
  </style>

  <div style="padding: 15px; text-align: center;">
    <img src="/nen-web.jpg" class="banner-chinh-anh" alt="Hoa Tươi Thanh Ngọc">
  </div>

  <div class="luoi-san-pham" id="danhSachHoa"
    style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; padding: 15px;">
    <% danhSach.forEach((item, index)=> { %>
      <div class="the-san-pham">
        <a href="/san-pham/<%= item.slug %>">
          <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>"
            style="width:100%; border-radius:15px; height: 180px; object-fit: cover;">
        </a>
        <h3 style="font-size:14px; margin: 10px 0; height: 40px; overflow: hidden; color: #333;">
          <%= item.ten %>
        </h3>
        <a href="/san-pham/<%= item.slug %>"
          style="background:#0a7c76; color:white; text-decoration:none; padding:8px 18px; border-radius:20px; display:inline-block; font-size:12px; font-weight: bold;">Xem
          Chi Tiết</a>
      </div>
      <% }) %>
  </div>

  <div class="khu-vuc-nut">
    <button id="nut-xem-them" style="display: none;">Xem thêm sản phẩm</button>
  </div>

  <hr style="border: 0.5px solid #e0eceb; margin: 50px 0;">
  <div class="blog-section" style="max-width: 1200px; margin: 0 auto; padding: 0 20px; text-align: center;">
    <h2 style="color: #0a7c76; font-weight: bold;">📖 Cẩm Nang Hoa Tươi</h2>
    <p style="color: #666; margin-bottom: 30px;">Kinh nghiệm tặng hoa & chăm sóc hoa từ chuyên gia Thanh Ngọc</p>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; text-align: left;">
      <div style="background: white; border-radius: 15px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <h4 style="color: #333;">5 Bí kíp giữ hoa tươi lâu tại nhà</h4>
        <p style="font-size: 14px; color: #777;">Giúp bó hoa của bạn luôn rạng rỡ suốt cả tuần...</p>
        <a href="#" style="color: #e5732a; font-weight: bold; text-decoration: none; font-size: 14px;">Đọc tiếp →</a>
      </div>
      <div style="background: white; border-radius: 15px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <h4 style="color: #333;">Tặng hoa khai trương rước tài lộc</h4>
        <p style="font-size: 14px; color: #777;">Chọn hoa phong thủy cho ngày khai trương hồng phát...</p>
        <a href="#" style="color: #e5732a; font-weight: bold; text-decoration: none; font-size: 14px;">Đọc tiếp →</a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const items = document.querySelectorAll('.the-san-pham');
      const btn = document.getElementById('nut-xem-them');
      let hienTai = 20; // Ban đầu hiện 20 ảnh

      const capNhatHienThi = () => {
        items.forEach((item, i) => {
          if (i < hienTai) {
            item.style.display = 'block';
            setTimeout(() => item.classList.add('hien-ra'), i * 30);
          } else {
            item.style.display = 'none';
          }
        });
        btn.style.display = hienTai < items.length ? 'inline-block' : 'none';
      };

      btn.addEventListener('click', () => {
        hienTai += 20;
        capNhatHienThi();
      });

      capNhatHienThi(); // Chạy khi vừa load trang
    });
  </script>

  <%- include('partials/footer') %>