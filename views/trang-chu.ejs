<%- include('partials/header') %>
  <style>
    /* 1. XÓA CHỮ TRÙNG LẶP */
    .logo-shop,
    .thanh-menu-chinh .logo-area,
    .logo-tron {
      display: none !important;
    }

    /* 2. HIỆU ỨNG CHUYỂN ĐỘNG (SCROLL) */
    .the-san-pham {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s ease-out;
    }

    .the-san-pham.hien-ra {
      opacity: 1;
      transform: translateY(0);
    }

    /* ZOOM ẢNH KHI DI CHUỘT */
    .the-san-pham:hover img {
      transform: scale(1.1) !important;
      transition: 0.4s !important;
    }

    /* 3. NÚT XEM THÊM CHUYÊN NGHIỆP */
    .khu-vuc-nut {
      text-align: center;
      margin: 40px 0;
      width: 100%;
    }

    #nut-xem-them {
      background: #0a7c76;
      color: white;
      border: none;
      padding: 12px 35px;
      border-radius: 30px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 4px 15px rgba(10, 124, 118, 0.3);
