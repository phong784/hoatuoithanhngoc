    <div class="luoi-san-pham" id="danhSachHoa">
      <% danhSach.forEach((item, index)=> { %>
        <div class="the-san-pham" data-delay="<%= (index * 0.05).toFixed(2) %>">
          <a href="/san-pham/<%= item.slug %>">
            <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>" decoding="async">
          </a>
          <h3 class="ten-hoa-hien-thi">
            <%= item.ten %>
          </h3>
          <a href="/san-pham/<%= item.slug %>" class="btn-chi-tiet">Xem Chi Tiết</a>
        </div>
        <% }) %>
    </div>

    <div style="text-align: center; margin: 10px 0 40px; width: 100%;">
      <button id="nut-xem-them"
        style="background: linear-gradient(135deg, #0A7C76, #149c95); color: white; padding: 12px 40px; border: none; border-radius: 25px; font-weight: bold; font-size: 16px; box-shadow: 0 4px 10px rgba(10, 124, 118, 0.2); cursor: pointer; transition: all 0.3s; display: none;">
        Xem thêm hoa...
      </button>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const danhSachHoa = Array.from(document.querySelectorAll('.the-san-pham'));
        const nutXemThem = document.getElementById('nut-xem-them');
        const oTimKiem = document.getElementById('oTimKiem');

        let soHoaHienTai = 10; // Hiện 10 lẵng đầu
        const soHoaThem = 10;  // Mỗi lần bấm xổ thêm 10 lẵng

        // Hàm điều khiển hiển thị số lượng hoa
        function capNhatHienThi() {
          danhSachHoa.forEach((hoa, index) => {
            if (index >= soHoaHienTai) {
              hoa.style.display = 'none';
            } else {
              hoa.style.display = 'block';
            }
          });

          // Giấu hoặc hiện nút "Xem thêm"
          if (soHoaHienTai >= danhSachHoa.length) {
            nutXemThem.style.display = 'none';
          } else {
            nutXemThem.style.display = 'inline-block';
          }
        }

        // 1. Chạy hàm giấu bớt hoa ngay khi vừa load web
        if (danhSachHoa.length > 0) {
          capNhatHienThi();
        }

        // 2. Xử lý khi khách bấm nút "Xem thêm hoa"
        nutXemThem.addEventListener('click', function () {
          soHoaHienTai += soHoaThem; // Cộng thêm 10 hoa
          capNhatHienThi(); // Cập nhật lại giao diện
        });

        // 3. Xử lý khi khách gõ tìm kiếm
        oTimKiem.addEventListener('input', function () {
          let tuKhoa = this.value.toLowerCase().trim();

          if (tuKhoa === '') {
            // Nếu xóa trắng ô tìm kiếm -> Trả lại trạng thái Xem thêm
            capNhatHienThi();
          } else {
            // Nếu đang tìm kiếm -> Ẩn nút xem thêm, bung toàn bộ hoa ra tìm
            nutXemThem.style.display = 'none';
            danhSachHoa.forEach(sanPham => {
              let tenHoa = sanPham.querySelector('.ten-hoa-hien-thi').textContent.toLowerCase();
              sanPham.style.display = tenHoa.includes(tuKhoa) ? 'block' : 'none';
            });
          }
        });

        // Hiệu ứng delay rơi từng lẵng hoa
        document.querySelectorAll('.the-san-pham').forEach(element => {
          const delay = element.getAttribute('data-delay');
          element.style.animationDelay = delay + 's';
        });
      });
    </script>

