<%- include('partials/header') %>

<style>
  /* 1. DỌN DẸP CHỮ THỪA & NỀN WEB */
  .logo-shop, .thanh-menu-chinh .logo-area, .logo-tron { display: none !important; }
  
  body {
    background: linear-gradient(135deg, #fdfbf7 0%, #eef7f6 100%);
    background-attachment: fixed;
    font-family: 'Quicksand', sans-serif;
  }

  /* 2. BANNER & TÌM KIẾM */
  .banner-chinh img {
    width: 100%; height: 220px; object-fit: cover;
    border-radius: 16px; box-shadow: 0 8px 20px rgba(10, 124, 118, 0.15);
  }

  /* 3. HIỆU ỨNG HOA BAY & ZOOM */
  .the-san-pham {
    opacity: 0; transform: translateY(30px);
    transition: all 0.6s ease-out;
  }
  .the-san-pham.hien-ra { opacity: 1; transform: translateY(0); }

  .the-san-pham:hover { transform: translateY(-10px) !important; }
  .the-san-pham:hover img { transform: scale(1.1) !important; transition: 0.4s !important; }

  /* 4. NÚT XEM THÊM */
  .khu-vuc-nut { text-align: center; margin: 40px 0; width: 100%; }
  #nut-xem-them {
    background: #0a7c76; color: white; border: none;
    padding: 12px 35px; border-radius: 30px; font-weight: bold;
    cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(10,124,118,0.3);
  }
</style>

<div class="banner-chinh" style="padding: 15px; text-align: center;">
    <img src="/nen-web.jpg" alt="Banner Thanh Ngọc">
</div>

<div class="luoi-san-pham" id="danhSachHoa">
    <% danhSach.forEach((item, index)=> { %>
      <div class="the-san-pham">
        <a href="/san-pham/<%= item.slug %>">
          <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>" style="width:100%; border-radius:15px;">
        </a>
        <h3 style="font-size:15px; margin: 10px 0;"><%= item.ten %></h3>
        <a href="/san-pham/<%= item.slug %>" class="btn-chi-tiet" style="text-decoration:none; color:#0a7c76; font-weight:bold;">Xem Chi Tiết</a>
      </div>
    <% }) %>
</div>

<div class="khu-vuc-nut">
  <button id="nut-xem-them" style="display: none;">Xem thêm sản phẩm</button>
</div>

<hr style="border: 0.5px solid #e0eceb; margin: 50px 0;">
<div class="blog-section" style="max-width: 1200px; margin: 0 auto; padding: 0 15px;">
    <h2 style="text-align: center; color: #0a7c76;">📖 Cẩm Nang Hoa Tươi</h2>
    <div class="blog-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        <div class="blog-card" style="background: white; border-radius: 15px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h3>5 Bí kíp giữ hoa tươi lâu</h3>
            <p>Làm sao để hoa giữ được vẻ đẹp rực rỡ suốt cả tuần?</p>
            <a href="#" style="color: #e5732a; font-weight: bold; text-decoration: none;">Xem ngay →</a>
        </div>
        <div class="blog-card" style="background: white; border-radius: 15px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h3>Hoa Khai Trương tài lộc</h3>
            <p>Chọn màu sắc hoa hợp phong thủy cho gia chủ...</p>
            <a href="#" style="color: #e5732a; font-weight: bold; text-decoration: none;">Xem ngay →</a>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const items = document.querySelectorAll('.the-san-pham');
    const btn = document.getElementById('nut-xem-them');
    let hienTai = 20; // Hiện 20 ảnh

    const capNhat = () => {
        items.forEach((item, i) => {
            item.style.display = i < hienTai ? 'block' : 'none';
        });
        btn.style.display = hienTai < items.length ? 'inline-block' : 'none';
        
        // Kích hoạt hiệu ứng bay lên
        setTimeout(() => {
            items.forEach((item, i) => {
                if(i < hienTai) item.classList.add('hien-ra');
            });
        }, 100);
    };

    btn.addEventListener('click', () => { hienTai += 20; capNhat(); });
    capNhat();
});
</script>

<%- include('partials/footer') %>