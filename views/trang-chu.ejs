<%- include('partials/header') %>
<style>
  body {
    background: linear-gradient(to bottom, #0a7c76 0%, #fdfbf7 50%, #fcdcb0 100%);
    background-attachment: fixed;
    background-repeat: no-repeat;
    background-size: cover;
    min-height: 100vh;
    margin: 0;
    font-family: 'Quicksand', sans-serif;
    color: #333;
  }
  .banner-chinh { text-align: center; max-width: 1200px; margin: 0 auto 10px; }
  .banner-chinh img { width: 100%; height: auto; object-fit: cover; }
  .danh-muc-nhanh {
    display: flex; overflow-x: auto; gap: 12px; padding: 10px 20px; margin-bottom: 20px;
    white-space: nowrap; -ms-overflow-style: none; scrollbar-width: none; max-width: 1200px; margin: 0 auto 20px;
  }
  .danh-muc-nhanh::-webkit-scrollbar { display: none; }
  .chip-danh-muc {
    background-color: #ffffff; color: #0A7C76; padding: 8px 20px; border-radius: 20px;
    text-decoration: none; font-size: 14px; font-weight: 700; border: 1px solid #0A7C76;
    transition: all 0.3s ease; box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  .chip-danh-muc:hover, .chip-danh-muc.active { background-color: #0A7C76; color: #ffffff; }
  .khung-tim-kiem { max-width: 600px; margin: 15px auto 25px; padding: 0 20px; position: relative; }
  .khung-tim-kiem .icon-tim-kiem { position: absolute; left: 35px; top: 50%; transform: translateY(-50%); font-size: 16px; pointer-events: none; color: #0a7c76; }
  .khung-tim-kiem input { width: 100%; padding: 14px 20px 14px 45px; border-radius: 30px; border: none; font-size: 15px; outline: none; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: all 0.3s ease; box-sizing: border-box; }
  .luoi-san-pham { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; padding: 0 20px 40px; max-width: 1200px; margin: 0 auto; }
  .the-san-pham { border: 1px solid #eee; border-radius: 15px; overflow: hidden; text-align: center; background: #fff; transition: transform 0.3s ease; padding-bottom: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  
  /* Đã xóa nền xanh giật lag ở đây */
  .the-san-pham img { width: 100%; height: 250px; object-fit: cover; }
  
  .the-san-pham h3 { font-size: 16px; color: #333; margin: 15px 10px; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 40px; }
  .the-san-pham a { display: inline-block; padding: 8px 20px; background-color: #ffffff; color: #0A7C76; text-decoration: none; border: 1px solid #0A7C76; border-radius: 20px; font-weight: 600; transition: all 0.3s; }
  
  @media (max-width: 768px) {
    .banner-chinh { padding: 0 10px; }
    .banner-chinh img { height: auto; border-radius: 10px; }
    .luoi-san-pham { grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 0 10px 40px; }
    .the-san-pham img { height: 160px; }
    .the-san-pham h3 { font-size: 13px; margin: 10px 5px; height: 35px; }
    .the-san-pham a { padding: 6px 12px; font-size: 12px; }
    .khung-tim-kiem { padding: 0 10px; margin-top: 15px; }
  }
</style>

<div class="banner-chinh">
  <img src="/nen-web.jpg" alt="Hoa Tươi Thanh Ngọc" onerror="this.style.display='none'">
</div>

<div class="khung-tim-kiem">
  <span class="icon-tim-kiem">🔍</span>
  <input type="text" id="oTimKiem" placeholder="Bạn cần tìm hoa gì (vd: khai trương, bó hoa)...">
</div>

<div class="danh-muc-nhanh">
  <a href="/" class="chip-danh-muc active">Tất Cả</a>
  <a href="/?danhmuc=Hoa Khai Trương" class="chip-danh-muc">Khai Trương</a>
  <a href="/?danhmuc=Hoa Kính Viếng" class="chip-danh-muc">Kính Viếng</a> 
  <a href="/?danhmuc=Bó Hoa" class="chip-danh-muc">Bó Hoa</a>
  <a href="/?danhmuc=Lẵng/Giỏ Hoa" class="chip-danh-muc">Lẵng/Giỏ</a>
  <a href="/?danhmuc=Hoa Để Bàn" class="chip-danh-muc">Hoa Để Bàn</a>
  <a href="/?danhmuc=Hoa Baby" class="chip-danh-muc">Hoa Baby</a>
</div>

<div class="luoi-san-pham" id="danhSachHoa">
  <% danhSach.forEach(item => { %>
    <div class="the-san-pham">
      <a href="/san-pham/<%= item.slug %>">
        <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>" decoding="async">
      </a>
      <h3 class="ten-hoa-hien-thi"><%= item.ten %></h3>
      <a href="/san-pham/<%= item.slug %>">Xem Chi Tiết</a>
    </div>
  <% }) %>
</div>

<script>
  document.getElementById('oTimKiem').addEventListener('input', function() {
    let tuKhoa = this.value.toLowerCase().trim();
    let cacSanPham = document.querySelectorAll('.the-san-pham');
    cacSanPham.forEach(sanPham => {
      let tenHoa = sanPham.querySelector('.ten-hoa-hien-thi').textContent.toLowerCase();
      sanPham.style.display = tenHoa.includes(tuKhoa) ? 'block' : 'none';
    });
  });
</script>
<%- include('partials/footer') %>