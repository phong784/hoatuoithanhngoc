      <button id="nut-xem-them" style="display: none;">Xem thêm hoa...</button>

      <script>
        // 4. BỘ NÃO XỬ LÝ: CHỈ HIỆN 12 ẢNH ĐẦU TIÊN
        document.addEventListener("DOMContentLoaded", function () {
          const danhSachHoa = document.querySelectorAll('.the-san-pham');
          const nutXemThem = document.getElementById('nut-xem-them');
          let soHoaHienTai = 12; // Ban đầu chỉ hiện 12 lẵng cho gọn

          if (danhSachHoa.length > 0) {
            // Giấu bớt đi
            danhSachHoa.forEach((hoa, index) => {
              if (index >= soHoaHienTai) hoa.style.display = 'none';
            });

            // Hiện nút "Xem thêm" nếu còn hoa bị giấu
            if (danhSachHoa.length > soHoaHienTai) nutXemThem.style.display = 'block';

            // Khi khách bấm nút
            nutXemThem.addEventListener('click', function () {
              let soHoaTiepTheo = soHoaHienTai + 12; // Bấm thì xổ thêm 12 lẵng nữa
              for (let i = soHoaHienTai; i < soHoaTiepTheo; i++) {
                if (danhSachHoa[i]) danhSachHoa[i].style.display = 'block';
              }
              soHoaHienTai = soHoaTiepTheo;
              // Hết hoa thì ẩn nút đi
              if (soHoaHienTai >= danhSachHoa.length) nutXemThem.style.display = 'none';
            });
          }
        });
      </script>