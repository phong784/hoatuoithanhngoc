<%- include('partials/header') %>

  <style>
    /* 1. XÓA CHỮ DƯ & FIX NỀN */
    .logo-shop,
    .thanh-menu-chinh .logo-area,
    .logo-tron,
    .logo-area {
      display: none !important;
    }

    body {
      background: linear-gradient(135deg, #fdfbf7 0%, #eef7f6 100%) !important;
      background-attachment: fixed !important;
      font-family: 'Quicksand', sans-serif;
      margin: 0;
      padding: 0;
    }

    /* 2. BANNER */
    .banner-chinh img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 8px 20px rgba(10, 124, 118, 0.15);
    }

    /* 3. HIỆU ỨNG HOA BAY */
    .the-san-pham {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s ease-out;
    }

    .the-san-pham.hien-ra {
      opacity: 1;
      transform: translateY(0);
    }

    .the-san-pham:hover {
      transform: translateY(-10px) !important;
    }

    /* 4. NÚT XEM THÊM */
    .khu-vuc-nut {
      text-align: center;
      margin: 40px 0;
      width: 100%;
    }

    #nut-xem-them {
      background: #0a7c76;
      color: white;
      border: none;
      padding: 12px 35px;
      border-radius: 30px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
    }
  </style>

  <div class="banner-chinh" style="padding: 15px; text-align: center;">
    <img src="/nen-web.jpg" alt="Banner">
  </div>

  <div class="luoi-san-pham" id="danhSachHoa"
    style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; padding: 15px;">
    <% danhSach.forEach((item, index)=> { %>
      <div class="the-san-pham">
        <a href="/san-pham/<%= item.slug %>">
          <img src="<%= item.hinhAnh %>" alt="<%= item.ten %>"
            style="width:100%; border-radius:15px; height: 180px; object-fit: cover;">
        </a>
        <h3 style="font-size:14px; margin: 10px 0; height: 40px; overflow: hidden;">
          <%= item.ten %>
        </h3>
        <a href="/san-pham/<%= item.slug %>"
          style="background:#0a7c76; color:white; text-decoration:none; padding:8px 15px; border-radius:20px; display:inline-block; font-size:12px;">Xem
          Chi Tiết</a>
      </div>
      <% }) %>
  </div>

  <div class="khu-vuc-nut">
    <button id="nut-xem-them" style="display: none;">Xem thêm sản phẩm</button>
  </div>

  <hr style="border: 0.5px solid #e0eceb; margin: 50px 0;">
  <div style="text-align: center; padding: 20px;">
    <h2 style="color: #0a7c76;">📖 Cẩm Nang Hoa Tươi</h2>
    <p>Nơi chia sẻ kiến thức về hoa...</p>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const items = document.querySelectorAll('.the-san-pham');
      const btn = document.getElementById('nut-xem-them');
      let hienTai = 20;
FF
      const capNhat = () => {
        items.forEach((item, i) => {
          item.style.display = i < hienTai ? 'block' : 'none';
        });
        btn.style.display = hienTai < items.length ? 'inline-block' : 'none';
        setTimeout(() => {
          items.forEach((item, i) => { if (i < hienTai) item.classList.add('hien-ra'); });
        }, 100);
      };

      btn.addEventListener('click', () => { hienTai += 20; capNhat(); });
      capNhat();
    });
  </script>

  <%- include('partials/footer') %>