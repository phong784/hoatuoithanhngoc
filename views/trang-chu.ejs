  <div class="khu-vuc-nut">
    <button id="nut-xem-them" style="display: none;">Xem thêm sản phẩm</button>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const items = document.querySelectorAll('.the-san-pham');
      const btn = document.getElementById('nut-xem-them');
      let hienTai = 20; // Hiện 20 ảnh đầu tiên theo ý bạn

      // Hàm kiểm tra hiệu ứng khi cuộn chuột
      const checkScroll = () => {
        items.forEach(item => {
          if (item.getBoundingClientRect().top < window.innerHeight * 0.9) {
            item.classList.add('hien-ra');
          }
        });
      };

      const capNhat = () => {
        items.forEach((item, i) => {
          item.style.display = i < hienTai ? 'block' : 'none';
        });
        btn.style.display = hienTai < items.length ? 'inline-block' : 'none';
        checkScroll();
      };

      window.addEventListener('scroll', checkScroll);
      btn.addEventListener('click', () => { hienTai += 20; capNhat(); });

      capNhat(); // Chạy lần đầu
    });
  </script>
  .the-san-pham {
  border-radius: 20px;
  overflow: hidden;
  text-align: center;
  background: #fff;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  padding-bottom: 20px;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
  border: none;
  position: relative;
  }

  .the-san-pham:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 35px rgba(10, 124, 118, 0.15);
  }

  .the-san-pham img {
  width: 100%;
  height: 280px;
  object-fit: cover;
  border-bottom: 1px solid #f0f0f0;
  }

  .the-san-pham h3 {
  font-size: 16px;
  color: #2c3e50;
  margin: 15px 15px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 44px;
  font-weight: 700;
  line-height: 1.4;
  }

  .the-san-pham a.btn-chi-tiet {
  display: inline-block;
  padding: 10px 25px;
  background: linear-gradient(135deg, #0A7C76, #149c95);
  color: #ffffff;
  text-decoration: none;
  border-radius: 25px;
  font-weight: bold;
  font-size: 14px;
  transition: all 0.3s;
  box-shadow: 0 4px 10px rgba(10, 124, 118, 0.2);
  }

  .the-san-pham a.btn-chi-tiet:hover {
  background: linear-gradient(135deg, #08615c, #0A7C76);
  box-shadow: 0 6px 15px rgba(10, 124, 118, 0.3);
  }

  /* --- TỐI ƯU CỰC MƯỢT CHO ĐIỆN THOẠI --- */
